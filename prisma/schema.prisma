generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String             @id @default(cuid())
  name         String?
  email        String?            @unique
  phone        String?
  passwordHash String?
  role         Role               @default(CUSTOMER)
  createdAt    DateTime           @default(now())
  addresses    Address[]
  orders       Order[]
  pushSubs     PushSubscription[]
  reviews      Review[]
}

model Address {
  id        String  @id @default(cuid())
  userId    String
  label     String
  area      String
  landmark  String?
  isPrimary Boolean @default(false)
  user      User    @relation(fields: [userId], references: [id])
}

model Order {
  id               String        @id @default(cuid())
  trackingToken    String        @unique @default(cuid())
  userId           String?
  guestName        String?
  guestPhone       String?
  guestEmail       String?
  subtotalKes      Float
  deliveryFeeKes   Float         @default(0)
  totalKes         Float
  displayCurrency  String        @default("KES")
  displayTotal     Float
  fulfillment      Fulfillment   @default(DELIVERY)
  deliveryArea     String?
  deliveryLandmark String?
  status           OrderStatus   @default(PENDING)
  paymentStatus    PaymentStatus @default(UNPAID)
  paymentMethod    PaymentMethod @default(MPESA)
  mpesaCheckoutId  String?
  mpesaRef         String?
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  user             User?         @relation(fields: [userId], references: [id])
  items            OrderItem[]
}

model OrderItem {
  id            String @id @default(cuid())
  orderId       String
  sanityId      String
  productName   String
  quantity      Int
  unitPriceKes  Float
  totalPriceKes Float
  order         Order  @relation(fields: [orderId], references: [id])
}

model CustomOrder {
  id            String    @id @default(cuid())
  fullName      String
  phone         String
  email         String?
  occasion      String
  description   String
  flavors       String?
  servings      Int?
  preferredDate DateTime?
  fulfillment   String
  deliveryArea  String?
  budgetRange   String?
  notes         String?
  status        String    @default("NEW")
  createdAt     DateTime  @default(now())
}

model Review {
  id         String   @id @default(cuid())
  userId     String?
  sanityId   String
  orderId    String?
  rating     Int
  body       String
  isVerified Boolean  @default(false)
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])

  @@unique([userId, sanityId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userId    String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model ConsentLog {
  id        String   @id @default(cuid())
  accepted  Boolean
  userAgent String?
  createdAt DateTime @default(now())
}

model StaffRole {
  id          String         @id @default(cuid())
  name        String         @unique
  description String?
  permissions String[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  staff       StaffAccount[]
}

model StaffAccount {
  id           String      @id @default(cuid())
  name         String
  email        String      @unique
  phone        String?
  passwordHash String?
  isSuperAdmin Boolean     @default(false)
  roleId       String?
  status       StaffStatus @default(INVITED)
  inviteToken  String?     @unique
  inviteExpiry DateTime?
  lastLogin    DateTime?
  createdAt    DateTime    @default(now())
  role         StaffRole?  @relation(fields: [roleId], references: [id])

  @@map("staff_accounts")
}

model OrderStatusLog {
  id        String   @id @default(cuid())
  orderId   String
  status    String
  changedBy String
  note      String?
  createdAt DateTime @default(now())

  @@map("order_status_logs")
}

model StaffInvite {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique
  roleId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("staff_invites")
}

model PaymentLog {
  id          String   @id @default(cuid())
  orderId     String
  reference   String
  status      String
  amount      Float?
  mpesaRef    String?
  phone       String?
  rawPayload  String
  processedAt DateTime @default(now())

  @@map("payment_logs")
}

enum Role {
  CUSTOMER
  ADMIN
}

enum Fulfillment {
  DELIVERY
  PICKUP
}

enum OrderStatus {
  PENDING
  CONFIRMED
  BAKING
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  COLLECTED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

enum PaymentMethod {
  MPESA
  CASH
}

enum StaffStatus {
  INVITED
  ACTIVE
  SUSPENDED
}
