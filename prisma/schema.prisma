// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String             @id @default(cuid())
  name         String?
  email        String?            @unique
  phone        String?
  passwordHash String?
  role         Role               @default(CUSTOMER)
  createdAt    DateTime           @default(now())
  orders       Order[]
  reviews      Review[]
  addresses    Address[]
  pushSubs     PushSubscription[]
}

enum Role {
  CUSTOMER
  ADMIN
}

model Address {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  label     String
  area      String
  landmark  String?
  isPrimary Boolean @default(false)
}

model Order {
  id               String        @id @default(cuid())
  trackingToken    String        @unique @default(cuid())
  userId           String?
  user             User?         @relation(fields: [userId], references: [id])
  guestName        String?
  guestPhone       String?
  guestEmail       String?
  items            OrderItem[]
  subtotalKes      Float
  deliveryFeeKes   Float         @default(0)
  totalKes         Float
  displayCurrency  String        @default("KES")
  displayTotal     Float
  fulfillment      Fulfillment   @default(DELIVERY)
  deliveryArea     String?
  deliveryLandmark String?
  status           OrderStatus   @default(PENDING)
  paymentStatus    PaymentStatus @default(UNPAID)
  paymentMethod    PaymentMethod @default(MPESA)
  mpesaCheckoutId  String?
  mpesaRef         String?
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

enum Fulfillment {
  DELIVERY
  PICKUP
}

enum OrderStatus {
  PENDING
  CONFIRMED
  BAKING
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  COLLECTED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

enum PaymentMethod {
  MPESA
  CASH
}

model OrderItem {
  id            String @id @default(cuid())
  orderId       String
  order         Order  @relation(fields: [orderId], references: [id])
  sanityId      String
  productName   String
  quantity      Int
  unitPriceKes  Float
  totalPriceKes Float
}

model CustomOrder {
  id            String    @id @default(cuid())
  fullName      String
  phone         String
  email         String?
  occasion      String
  description   String
  flavors       String?
  servings      Int?
  preferredDate DateTime?
  fulfillment   String
  deliveryArea  String?
  budgetRange   String?
  notes         String?
  status        String    @default("NEW")
  createdAt     DateTime  @default(now())
}

model Review {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  sanityId   String
  orderId    String?
  rating     Int
  body       String
  isVerified Boolean  @default(false)
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@unique([userId, sanityId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}
