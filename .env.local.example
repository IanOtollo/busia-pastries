// ──────────────────────────────────────────────────────────
// Clare Pastries — Environment Variables Template
// Copy this file to .env.local and fill in your credentials.
// NEVER commit .env.local to version control.
// ──────────────────────────────────────────────────────────

# ── DATABASE ──────────────────────────────────────────────
# Supabase → Settings → Database → Connection String → Nodejs (with PgBouncer)
DATABASE_URL=postgresql://postgres:[password]@[host]:6543/postgres?pgbouncer=true

# Supabase → Settings → Database → Connection String → Direct
DIRECT_URL=postgresql://postgres:[password]@[host]:5432/postgres

# ── SUPABASE ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── NEXT AUTH ─────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-super-secret-random-string
# During dev: http://localhost:3000 | In prod: https://yourdomain.com
NEXTAUTH_URL=http://localhost:3000

# ── SANITY ────────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=your-sanity-project-id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=sk...

# ── PAYHERO KENYA (NCBA LOOP) ───────────────────────────
# https://app.payhero.co.ke → Dashboard → API Credentials
PAYHERO_API_ID=your-api-username
PAYHERO_API_KEY=your-api-password
PAYHERO_CHANNEL_ID=your-paybill-channel-id
PAYHERO_API_URL=https://app.payhero.co.ke/api/v1
# NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── M-PESA DARAJA (LEGACY/BACKUP) ───────────────────────────
# https://developer.safaricom.co.ke
MPESA_CONSUMER_KEY=your-daraja-consumer-key
MPESA_CONSUMER_SECRET=your-daraja-consumer-secret
MPESA_PASSKEY=your-lipa-na-mpesa-passkey
MPESA_SHORTCODE=174379
MPESA_CALLBACK_URL=https://your-ngrok-or-vercel-url.com/api/checkout/mpesa/callback
MPESA_ENVIRONMENT=sandbox

# ── UPSTASH REDIS ─────────────────────────────────────────
# https://console.upstash.com → Create Database → REST API
UPSTASH_REDIS_REST_URL=https://your-upstash-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── RESEND (EMAIL) ────────────────────────────────────────
# https://resend.com → API Keys → Create key
RESEND_API_KEY=re_...

# ── WEB PUSH VAPID KEYS ───────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BA...
VAPID_PRIVATE_KEY=your-private-key

# ── SENTRY ────────────────────────────────────────────────
# https://sentry.io → Project → Settings → Client Keys (DSN)
SENTRY_DSN=https://your-key@sentry.io/your-project-id

# ── APP URL (used internally) ─────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
